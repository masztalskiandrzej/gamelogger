<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameLogger</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GameLogger.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Animated Background -->
    <div class="bg-animation">
        <div class="grid-lines"></div>
        <div class="particles">
            <span></span><span></span><span></span><span></span><span></span>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="gaming-nav">
        <div class="nav-container">
            <div class="nav-brand">
                <i class="fas fa-gamepad"></i>
                <span class="brand-text">GAME<span class="brand-accent">LOGGER</span></span>
            </div>
            <ul class="nav-menu">
                <li class="nav-item">
                    <a class="nav-link active" href="/">
                        <i class="fas fa-th-large"></i>
                        <span>Panel Główny</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Home/Backlog">
                        <i class="fas fa-bookmark"></i>
                        <span>Backlog</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" onclick="openModal('gameModal'); return false;">
                        <i class="fas fa-plus-circle"></i>
                        <span>Dodaj Grę</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-section="stats">
                        <i class="fas fa-chart-bar"></i>
                        <span>Statystyki</span>
                    </a>
                </li>
            </ul>
            <div class="nav-user">
                <div class="user-avatar">
                    <i class="fas fa-user-astronaut"></i>
                </div>
                <span class="user-name">Gamer</span>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-container">
        @RenderBody()
    </div>

    <!-- Modals -->
    <div class="modal-overlay" id="gameModal">
        <div class="gaming-modal">
            <div class="modal-header">
                <h3 class="modal-title" id="modalTitle">Dodaj Nową Grę</h3>
                <button class="modal-close" onclick="closeModal('gameModal')">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div id="gameFormContainer">
                <!-- Form will be loaded here -->
                <partial name="_GameForm" model="new GameLogger.Models.Game()" />
            </div>
        </div>
    </div>

    <!-- Game Detail Modal -->
    <div class="modal-overlay" id="detailModal">
        <div class="gaming-modal detail-modal">
            <div class="modal-header">
                <h3 class="modal-title" id="detailTitle">Szczegóły Gry</h3>
                <button class="modal-close" onclick="closeModal('detailModal')">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body" id="detailContent">
                <!-- Content will be injected here -->
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
