@model GameLogger.Models.GameListViewModel
@{
    ViewData["Title"] = "GameLogger - Panel Główny";
}

<!-- Hero Section -->
<section class="hero-section">
    <h1 class="hero-title">WITAJ W GAMELOGGER</h1>
    <p class="hero-subtitle">Twoja osobista biblioteka gier z ocenami i recenzjami</p>
    <div class="hero-actions">
        <button class="gaming-btn primary" onclick="openModal('gameModal')">
            <i class="fas fa-plus"></i> Dodaj Grę
        </button>
        <a href="/Home/Backlog" class="gaming-btn secondary" style="text-decoration: none;">
            <i class="fas fa-bookmark"></i> Przeglądaj Backlog
        </a>
    </div>
</section>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon green">
            <i class="fas fa-trophy"></i>
        </div>
        <div class="stat-label">Ukończone Gry</div>
        <div class="stat-value">@Model.Games.Count</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="fas fa-star"></i>
        </div>
        <div class="stat-label">Średnia Ocena</div>
        <div class="stat-value">
            @(Model.Games.Any() ? Model.Games.Average(g => g.Rating).ToString("F1") : "0.0")
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">
            <i class="fas fa-clock"></i>
        </div>
        <div class="stat-label">Całkowity Czas</div>
        <div class="stat-value">
            @Model.Games.Sum(g => g.PlaytimeHours)<span class="stat-unit">h</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: rgba(0, 212, 255, 0.15); color: var(--accent-secondary);">
            <i class="fas fa-bookmark"></i>
        </div>
        <div class="stat-label">Backlog</div>
        <div class="stat-value">@Model.BacklogGames.Count</div>
    </div>
</div>

<!-- Currently Playing Banner -->
@if (Model.PlayingGames.Any())
{
    <section class="games-section">
        <div class="section-header">
            <h2 class="section-title">
                <i class="fas fa-gamepad" style="color: var(--accent-purple);"></i>
                Obecnie Gram
            </h2>
        </div>
        <div class="games-grid">
            @foreach (var game in Model.PlayingGames)
            {
                <div class="game-card playing-card" data-game-id="@game.Id">
                    <div class="status-badge playing">W TRAKCIE</div>
                    @if (!string.IsNullOrEmpty(game.CoverImageUrl))
                    {
                        <img src="@game.CoverImageUrl" alt="@game.Title" class="game-cover" onerror="this.parentElement.innerHTML='<div class=\'game-cover-placeholder\'><i class=\'fas fa-gamepad\'></i></div>'">
                    }
                    else
                    {
                        <div class="game-cover-placeholder">
                            <i class="fas fa-gamepad"></i>
                        </div>
                    }
                    <div class="game-info">
                        <h3 class="game-title">@game.Title</h3>
                        <div class="game-meta">
                            @if (!string.IsNullOrEmpty(game.Genre))
                            {
                                <span class="game-tag">@game.Genre</span>
                            }
                            <span class="game-tag" style="background: rgba(139, 92, 246, 0.1); border-color: rgba(139, 92, 246, 0.3); color: var(--accent-purple);">
                                @(game.PlaytimeHours)h
                            </span>
                        </div>
                        <div class="game-actions">
                            <button class="gaming-btn primary" onclick="changeGameStatus(@game.Id, 'Completed', event);">
                                <i class="fas fa-check"></i> Ukończ
                            </button>
                            <button class="gaming-btn secondary" onclick="openEditModal(@game.Id); event.stopPropagation();">
                                <i class="fas fa-edit"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- Games Section -->
<section class="games-section" id="gamesSection">
    <div class="section-header">
        <h2 class="section-title">
            <i class="fas fa-trophy" style="color: var(--accent-primary);"></i>
            Ukończone Gry
        </h2>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <select class="gaming-input" style="width: auto;" onchange="filterByGenre(this.value)">
                <option value="">Wszystkie Gatunki</option>
                @foreach (var genre in Model.Genres.Distinct())
                {
                    <option value="@genre">@genre</option>
                }
            </select>
            <select class="gaming-input" style="width: auto;" onchange="sortGames(this.value)">
                <option value="date">Sortuj: Data</option>
                <option value="rating">Sortuj: Ocena</option>
                <option value="title">Sortuj: Tytuł</option>
            </select>
        </div>
    </div>

    @if (Model.Games.Any())
    {
        <div class="games-grid">
            @foreach (var game in Model.Games)
            {
                <div class="game-card completed-card" data-game-id="@game.Id" data-rating="@game.Rating" data-genre="@game.Genre" data-date="@game.DatePlayed.ToString("o")">
                    <div class="status-badge completed">UKOŃCZONA</div>
                    @if (!string.IsNullOrEmpty(game.CoverImageUrl))
                    {
                        <img src="@game.CoverImageUrl" alt="@game.Title" class="game-cover" onerror="this.parentElement.innerHTML='<div class=\'game-cover-placeholder\'><i class=\'fas fa-gamepad\'></i></div>'">
                    }
                    else
                    {
                        <div class="game-cover-placeholder">
                            <i class="fas fa-gamepad"></i>
                        </div>
                    }
                    <div class="game-info">
                        <h3 class="game-title">@game.Title</h3>
                        <div class="game-meta">
                            @if (!string.IsNullOrEmpty(game.Genre))
                            {
                                <span class="game-tag">@game.Genre</span>
                            }
                            @if (!string.IsNullOrEmpty(game.Platform))
                            {
                                <span class="game-tag">@game.Platform</span>
                            }
                        </div>
                        <div class="game-rating">
                            <div class="rating-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Ceiling(game.Rating / 2.0))
                                    {
                                        <i class="fas fa-star filled"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-star empty"></i>
                                    }
                                }
                            </div>
                            <span class="rating-number">@game.Rating/10</span>
                        </div>
                        <div class="game-actions">
                            <button class="gaming-btn secondary" onclick="showGameDetails(@game.Id); event.stopPropagation();">
                                <i class="fas fa-eye"></i> Szczegóły
                            </button>
                            <button class="gaming-btn secondary" onclick="openEditModal(@game.Id); event.stopPropagation();">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="gaming-btn danger" onclick="deleteGame(@game.Id, '@game.Title.Replace("'", "\\'")'); event.stopPropagation();">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-trophy"></i>
            <h3>Brak ukończonych gier</h3>
            <p>Ukończ pierwszą grę lub dodaj coś do backlogu!</p>
            <button class="gaming-btn primary" onclick="openModal('gameModal')">
                <i class="fas fa-plus"></i> Dodaj Grę
            </button>
        </div>
    }
</section>

<script>
    function changeGameStatus(gameId, newStatus, event) {
        if (event) event.stopPropagation();

        fetch('/Home/ChangeStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `id=${gameId}&newStatus=${newStatus}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            }
        })
        .catch(error => {
            showNotification('Błąd podczas zmiany statusu', 'error');
        });
    }
</script>
